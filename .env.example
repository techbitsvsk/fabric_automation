# =============================================================================
# Fabric Control Plane — environment configuration
# Copy this file to .env and fill in your values.
# Lines marked REQUIRED must be set before the application will start.
# Lines marked OPTIONAL have defaults and can be left commented out.
# =============================================================================


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# OPTIONAL — set to true to skip JWT validation entirely (local dev only, never use in prod)
#DEV_MODE=false

# OPTIONAL — set to true to use DefaultAzureCredential (Managed Identity, az login, etc.)
#             set to false to use an explicit service principal (see below)
USE_AZURE_IDENTITY=true

# REQUIRED only when USE_AZURE_IDENTITY=false
# Service principal credentials for authenticating to Fabric, ARM, and Graph APIs.
#AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
#AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
#AZURE_CLIENT_SECRET=your-client-secret-here


# -----------------------------------------------------------------------------
# Azure subscription — REQUIRED
# -----------------------------------------------------------------------------

# The subscription that hosts your Fabric capacity, Log Analytics workspace,
# and where metric alert rules will be deployed.
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# The resource group used for ARM resources (diagnostic settings, alert rules).
AZURE_RESOURCE_GROUP=rg-fabric-platform


# -----------------------------------------------------------------------------
# Swagger UI — Entra ID OAuth2 login
# -----------------------------------------------------------------------------
# Register a Single-Page Application (SPA) app registration in Entra ID.
# Set its redirect URI to: http://localhost:8000/docs/oauth2-redirect
# Grant it the API permissions your app exposes (or openid/profile/email for
# basic identity). No client secret is needed — PKCE is used instead.

# REQUIRED to enable the Swagger Authorize button
SWAGGER_CLIENT_ID=00000000-0000-0000-0000-000000000000

# OPTIONAL — space-separated scopes shown in the Swagger authorize dialog
#SWAGGER_SCOPES=openid profile email


# -----------------------------------------------------------------------------
# API base URLs — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Microsoft Fabric REST API base URL.
# Override only if using a sovereign cloud or a mock server during development.
#FABRIC_BASE_URL=https://api.fabric.microsoft.com/v1

# Azure Resource Manager base URL.
# Override only for sovereign clouds (e.g. https://management.usgovcloudapi.net).
#ARM_BASE_URL=https://management.azure.com
